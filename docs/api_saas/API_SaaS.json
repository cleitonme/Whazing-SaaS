{
  "info": {
    "_postman_id": "03319d28-c5ce-46de-ac34-05f38e030ef3",
    "name": "API Whazing ADMIN",
    "description": "API de administração do Whazing SaaS. Substitua as variáveis URL_ADMIN, API_ID e TOKEN_ADMIN nas configurações da coleção.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "URL_ADMIN", "value": "https://SEU_BACKEND/v1/api/admin" },
    { "key": "API_ID", "value": "SEU_API_ID" },
    { "key": "TOKEN_ADMIN", "value": "SEU_BEARER_TOKEN" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{TOKEN_ADMIN}}", "type": "string" }]
  },
  "item": [
    {
      "name": "🏢 Tenants",
      "item": [
        {
          "name": "Criar Tenant",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Fulano de Tal\",\n  \"email\": \"fulano@exemplo.com\",\n  \"password\": \"mudar123\",\n  \"tenantName\": \"Empresa Exemplo\",\n  \"phone\": \"5548999990000\",\n  \"plano\": \"1\",\n  \"timetest\": \"7\",\n  \"recurrence\": \"MENSAL\",\n  \"status\": \"active\",\n  \"trial\": false,\n  \"affiliate\": false\n}"
            },
            "url": {
              "raw": "{{URL_ADMIN}}/{{API_ID}}/createtenant",
              "host": ["{{URL_ADMIN}}"],
              "path": ["{{API_ID}}", "createtenant"]
            },
            "description": "Cria um novo tenant com usuário admin.\n\n**recurrence**: MENSAL | BIMESTRAL | TRIMESTRAL | SEMESTRAL | ANUAL\n**timetest**: dias de trial\n**status**: active | inactive"
          }
        },
        {
          "name": "Editar Tenant",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenantId\": \"23\",\n  \"tenantName\": \"Empresa Atualizada\",\n  \"email\": \"novo@exemplo.com\",\n  \"phone\": \"5548999990001\",\n  \"plano\": \"2\",\n  \"dueDate\": \"2026-06-01T00:00:00\",\n  \"recurrence\": \"TRIMESTRAL\",\n  \"status\": \"active\"\n}"
            },
            "url": {
              "raw": "{{URL_ADMIN}}/{{API_ID}}/updatetenant",
              "host": ["{{URL_ADMIN}}"],
              "path": ["{{API_ID}}", "updatetenant"]
            },
            "description": "Atualiza dados do tenant. Ao alterar plano ou recorrência, as faturas abertas são recriadas automaticamente."
          }
        },
        {
          "name": "Listar Todos os Tenants",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{URL_ADMIN}}/{{API_ID}}",
              "host": ["{{URL_ADMIN}}"],
              "path": ["{{API_ID}}"]
            },
            "description": "Retorna todos os tenants cadastrados (exceto Tenant 1)."
          }
        },
        {
          "name": "Listar Tenant Específico",
          "request": {
            "method": "GET",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenantId\": \"23\"\n}"
            },
            "url": {
              "raw": "{{URL_ADMIN}}/{{API_ID}}",
              "host": ["{{URL_ADMIN}}"],
              "path": ["{{API_ID}}"]
            },
            "description": "Envia tenantId no body para filtrar somente aquele tenant."
          }
        },
        {
          "name": "Adicionar 1 Mês",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenantId\": \"23\"\n}"
            },
            "url": {
              "raw": "{{URL_ADMIN}}/{{API_ID}}/addMonth",
              "host": ["{{URL_ADMIN}}"],
              "path": ["{{API_ID}}", "addMonth"]
            },
            "description": "Adiciona exatamente 1 mês ao dueDate do tenant (independente da recorrência)."
          }
        }
      ]
    },

    {
      "name": "👤 Usuários",
      "item": [
        {
          "name": "Listar Usuários do Tenant",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{URL_ADMIN}}/{{API_ID}}/users/23",
              "host": ["{{URL_ADMIN}}"],
              "path": ["{{API_ID}}", "users", "23"]
            },
            "description": "Retorna todos os usuários ativos de um tenant."
          }
        },
        {
          "name": "Alterar Senha de Usuário",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"42\",\n  \"password\": \"novaSenha123\"\n}"
            },
            "url": {
              "raw": "{{URL_ADMIN}}/{{API_ID}}/users",
              "host": ["{{URL_ADMIN}}"],
              "path": ["{{API_ID}}", "users"]
            },
            "description": "Altera a senha de qualquer usuário (exceto do Tenant 1). Mínimo 6 caracteres."
          }
        }
      ]
    },

    {
      "name": "📦 Planos",
      "item": [
        {
          "name": "Listar Planos",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{URL_ADMIN}}/{{API_ID}}/plans",
              "host": ["{{URL_ADMIN}}"],
              "path": ["{{API_ID}}", "plans"]
            },
            "description": "Retorna todos os planos disponíveis ordenados pelo valor."
          }
        }
      ]
    },

    {
      "name": "🧾 Faturas",
      "item": [
        {
          "name": "Listar Todas as Faturas",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{URL_ADMIN}}/{{API_ID}}/invoices/23",
              "host": ["{{URL_ADMIN}}"],
              "path": ["{{API_ID}}", "invoices", "23"],
              "query": [
                { "key": "status", "value": "all", "description": "open | paid | (omitir = all)" }
              ]
            },
            "description": "Retorna histórico completo de faturas do tenant.\n\nQuery `status`:\n- `open` → somente em aberto\n- `paid` → somente pagas\n- omitido → todas"
          }
        },
        {
          "name": "Faturas em Aberto (atalho)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{URL_ADMIN}}/{{API_ID}}/invoices/23/open",
              "host": ["{{URL_ADMIN}}"],
              "path": ["{{API_ID}}", "invoices", "23", "open"]
            },
            "description": "Atalho para listar somente faturas com status `open`, ordenadas por vencimento."
          }
        },
        {
          "name": "Gerar Pagamento / QR Code PIX",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 99.90\n}"
            },
            "url": {
              "raw": "{{URL_ADMIN}}/{{API_ID}}/invoices/101/payment",
              "host": ["{{URL_ADMIN}}"],
              "path": ["{{API_ID}}", "invoices", "101", "payment"]
            },
            "description": "Gera cobrança via gateway configurado (Efi, Asaas, MercadoPago, Stripe, etc).\n\n**price** é opcional: se omitido usa o valor da fatura.\n\nResposta (varia por gateway):\n- URL: `{ urlPagamento: '...' }`\n- PIX: `{ qrcode: { qrcode: '...' }, valor: { original: 99.90 } }`"
          }
        },
        {
          "name": "Marcar como Paga (manual)",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{URL_ADMIN}}/{{API_ID}}/invoices/101/paid",
              "host": ["{{URL_ADMIN}}"],
              "path": ["{{API_ID}}", "invoices", "101", "paid"]
            },
            "description": "Baixa manual de fatura sem passar pelo gateway.\n\nExecuta o mesmo fluxo dos webhooks:\n1. Marca fatura como `paid`\n2. Estende `dueDate` do tenant conforme recorrência\n3. Emite evento Socket para o frontend\n4. Envia mensagem de confirmação (se configurado)"
          }
        },
        {
          "name": "Criar Cobrança Avulsa",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenantId\": \"23\",\n  \"detail\": \"Taxa de implantação\",\n  \"value\": 150.00,\n  \"dueDate\": \"2025-12-31\",\n  \"recurrence\": \"MENSAL\"\n}"
            },
            "url": {
              "raw": "{{URL_ADMIN}}/{{API_ID}}/invoices/create",
              "host": ["{{URL_ADMIN}}"],
              "path": ["{{API_ID}}", "invoices", "create"]
            },
            "description": "Cria uma fatura avulsa com valor e vencimento personalizados.\n\n`recurrence` é opcional — herda a recorrência do tenant se omitido.\n`detail` é opcional — usa nome do tenant por padrão."
          }
        },
        {
          "name": "Editar Fatura",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"detail\": \"Plano Pro - Corrigido\",\n  \"value\": 199.90,\n  \"dueDate\": \"2026-01-15\",\n  \"status\": \"open\"\n}"
            },
            "url": {
              "raw": "{{URL_ADMIN}}/{{API_ID}}/invoices/101",
              "host": ["{{URL_ADMIN}}"],
              "path": ["{{API_ID}}", "invoices", "101"]
            },
            "description": "Atualiza campos de uma fatura. Todos os campos são opcionais.\n\nNão é possível editar faturas já pagas (exceto para reabrir com `status: open`)."
          }
        },
        {
          "name": "Excluir Fatura",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{URL_ADMIN}}/{{API_ID}}/invoices/101",
              "host": ["{{URL_ADMIN}}"],
              "path": ["{{API_ID}}", "invoices", "101"]
            },
            "description": "Remove a fatura permanentemente e reprocessa as faturas abertas do tenant via InvoiceCreateJob."
          }
        },
        {
          "name": "Recriar Faturas do Tenant",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{URL_ADMIN}}/{{API_ID}}/invoices/23/recreate",
              "host": ["{{URL_ADMIN}}"],
              "path": ["{{API_ID}}", "invoices", "23", "recreate"]
            },
            "description": "Deleta todas as faturas abertas do tenant e recria a partir do InvoiceCreateJob.\n\nUtil após alterar plano, recorrência ou data de vencimento."
          }
        }
      ]
    }
  ]
}
